rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only the site owner may write. Add more emails to the list to grant access.
    function isOwner() {
      return request.auth != null && request.auth.token.email in [
        "admin@beyondpublicitymena.com",
        "admin@admin.com"
      ];
    }

    match /portfolio/{document=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /categories/{document=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /slideshow/{document=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /clients/{document=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /teamMembers/{document=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /services/{document=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /legalPages/{document=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Single-session enforcement. Each user manages their own session doc only.
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
