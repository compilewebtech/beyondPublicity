rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Only the site owner may write. Mirror of firestore.rules isOwner().
    function isOwner() {
      return request.auth != null && request.auth.token.email in [
        "admin@beyondpublicitymena.com",
        "admin@admin.com"
      ];
    }

    // Cap uploads: reject anything bigger than 10 MB or not an image.
    function isValidUpload() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /slideshow/{fileName} {
      allow read: if true;
      allow write: if isOwner() && isValidUpload();
      allow delete: if isOwner();
    }

    match /clients/{fileName} {
      allow read: if true;
      allow write: if isOwner() && isValidUpload();
      allow delete: if isOwner();
    }

    match /team/{fileName} {
      allow read: if true;
      allow write: if isOwner() && isValidUpload();
      allow delete: if isOwner();
    }
  }
}
